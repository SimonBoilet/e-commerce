RewriteEngine On
RewriteBase /
RewriteCond %{REQUEST_URI} !(/$|\.)
RewriteRule (.*) %{REQUEST_URI}/ [R=301,L]

RewriteRule ^backoffice/$ index.php?pageBO=dashboard [L]
RewriteRule ^backoffice/([a-zA-Z]+)/$ index.php?pageBO=$1 [L]
RewriteRule ^backoffice/([a-zA-Z]+)/([a-z0-9-]+)/$ index.php?pageBO=$1&id=$2 [L]

RewriteRule ^api/$ index.php?pageAPI=liste
RewriteRule ^api/([a-zA-Z]+)/$ index.php?pageAPI=$1

RewriteRule ^$ index.php?page=accueil
RewriteRule ^([a-zA-Z]+)/$ index.php?page=$1
RewriteRule ^([a-zA-Z]+)/([a-z0-9-]+)/$ index.php?page=$1&id=$2